# Django runtime
DEBUG=1
SECRET_KEY=change-me-in-real-environments
HOST=127.0.0.1
PORT=8000

# App URL + security
APP_BASE_URL=http://127.0.0.1:8000
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000
MICROSOFT_MAILBOX_EMAIL=dev@alshival.dev

# Storage paths
SQLITE_PATH=var/db.sqlite3
USER_DATA_ROOT=var/user_data
TEAM_DATA_ROOT=var/team_data
STATIC_ROOT=var/staticfiles

# Optional API ingest auth
ALSHIVAL_INGEST_API_KEY=

# Internal SDK cloud logs auto-configuration
# When enabled, app boot auto-configures Alshival SDK to write to the default global "Alshival" resource.
ALSHIVAL_SDK_AUTO_CONFIG=1
# Optional local route override (defaults to http://127.0.0.1:${PORT})
ALSHIVAL_SDK_LOCAL_BASE_URL=
# Default cloud forwarding threshold for auto-config is ERROR unless ALSHIVAL_CLOUD_LEVEL is explicitly set.
# Rotate runtime global key on interval (seconds). Default is 2700 (45 min).
ALSHIVAL_SDK_AUTO_ROTATE_KEY=1
ALSHIVAL_SDK_KEY_ROTATE_INTERVAL_SECONDS=2700
# Optional logger name override (comma-separated).
ALSHIVAL_SDK_LOGGER_NAMES=dashboard,alshival
# Default GitHub repositories linked to the bootstrapped global "Alshival" resource wiki sync.
ALSHIVAL_DEFAULT_RESOURCE_GITHUB_REPOSITORIES=Alshival-Ai/alshival
# Pull linked GitHub wiki pages into local resource wiki + KB on app boot.
ALSHIVAL_DEFAULT_RESOURCE_WIKI_SYNC_ON_BOOT=1
# Allow unauthenticated GitHub wiki sync for public repositories.
ALSHIVAL_GITHUB_WIKI_ALLOW_ANON=1

# GitHub MCP (local upstream service)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Codex Hacker Mode MCP auto-registration
WEB_TERMINAL_CODEX_MCP_ENABLED=1
# In docker-compose this should usually be http://mcp:8080/mcp/
WEB_TERMINAL_CODEX_MCP_URL=http://mcp:8080/mcp/
WEB_TERMINAL_CODEX_MCP_SERVER_NAME=alshival
WEB_TERMINAL_CODEX_MCP_API_KEY_HEADER=x-api-key
WEB_TERMINAL_CODEX_MCP_API_KEY_ENV=MCP_API_KEY
# Optional: injected into shell env for Codex MCP bearer token auth.
WEB_TERMINAL_CODEX_MCP_API_KEY=

# Optional Ask Asana MCP auth (MCP app OAuth token audience: mcp-service)
# Option A: direct short-lived access token
ASK_ASANA_MCP_ACCESS_TOKEN=
# Option B: automatic refresh
ASK_ASANA_MCP_REFRESH_TOKEN=
ASK_ASANA_MCP_CLIENT_ID=
ASK_ASANA_MCP_CLIENT_SECRET=
# Optional endpoint overrides
ASK_ASANA_MCP_UPSTREAM_URL=https://mcp.asana.com/v2/mcp
ASK_ASANA_MCP_TOKEN_ENDPOINT=https://app.asana.com/-/oauth_token
MCP_ASANA_UPSTREAM_URL=https://mcp.asana.com/v2/mcp

# Twilio fallback for MCP phone-auth validation (optional if stored in DB setup)
TWILIO_AUTH_TOKEN=

# Master key material used by the app (comma-separated supported).
# Example below is a valid ed25519 SSH public key.
ALSHIVAL_SSH_KEY_MASTER_KEYS=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINFIO4PXwmx9QQWyjjd135pBrVrfBJtk6M4ya3aWy+0V alshival-dev-template
